From 6362b6585bb23032c05f931061214c3695c27011 Mon Sep 17 00:00:00 2001
From: Gerald Tan <woefulwabbit@gmail.com>
Date: Sat, 11 Apr 2026 15:27:07 +0800
Subject: [PATCH 09/11] Fix cmake for cross-compiling (#8)

Co-authored-by: Gerald Tan <gerald_tan@ctl.creative.com>
---
 ggml/src/ggml-rknpu2/CMakeLists.txt | 9 +++++++--
 1 file changed, 7 insertions(+), 2 deletions(-)

diff --git a/ggml/src/ggml-rknpu2/CMakeLists.txt b/ggml/src/ggml-rknpu2/CMakeLists.txt
index 2d9395712..b62cda36f 100644
--- a/ggml/src/ggml-rknpu2/CMakeLists.txt
+++ b/ggml/src/ggml-rknpu2/CMakeLists.txt
@@ -22,8 +22,13 @@ target_link_libraries(ggml-rknpu2 PRIVATE
     ${CMAKE_CURRENT_SOURCE_DIR}/libs/librknnrt.so
 )
 
+target_link_options(ggml-rknpu2 PUBLIC
+    "-Wl,-rpath-link,${CMAKE_CURRENT_SOURCE_DIR}/libs"
+)
+
 # Adding OpenMP in build
 if(OpenMP_FOUND)
     add_definitions(-DHAVE_OPENMP=1)
-    list(APPEND CMAKE_CXX_FLAGS "${OpenMP_CXX_FLAGS}")
-endif()
\ No newline at end of file
+    target_compile_options(ggml-rknpu2 PRIVATE ${OpenMP_CXX_FLAGS})
+    target_link_libraries(ggml-rknpu2 PRIVATE ${OpenMP_CXX_FLAGS})
+endif()
